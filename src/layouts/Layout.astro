---
interface Props {
  title?: string;
  description?: string;
}

const { 
  title = 'Carlos Rodriguez | Full Stack Developer',
  description = 'Desarrollador Full Stack con orientación backend. Especializado en arquitecturas de microservicios, JavaScript, TypeScript y Java.'
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Carlos Rodriguez" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <div class="noise-overlay"></div>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
