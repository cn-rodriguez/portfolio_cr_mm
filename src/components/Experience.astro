---
const experiences = [
  {
    company: 'Usercode SpA',
    period: 'Agosto 2024 – Actualidad',
    role: 'Desarrollador Full Stack',
    location: 'Santiago, Chile · Remoto',
    description: 'Desarrollo de software a medida y mantenimiento evolutivo de sistemas productivos para distintos clientes. Participación en más de 10 proyectos privados con alta complejidad técnica, incluyendo sistemas de microservicios con funcionalidad parcialmente no documentada.',
    highlight: '+10 proyectos privados',
    technologies: ['React', 'Next.js 15', 'Angular 8', 'Node.js', 'Express', 'AdonisJS 6', 'Spring Boot 2.6', 'Laravel', 'TypeScript', 'Java 8', 'SQL Server', 'PostgreSQL'],
    note: 'Proyectos bajo NDA · No distribuibles'
  },
  {
    company: 'Corporación Educacional Aventura',
    period: 'Diciembre 2022 – Febrero 2023',
    role: 'Desarrollador Full Stack · Práctica',
    location: 'Coquimbo, Chile',
    description: 'Diseño y desarrollo completo de una plataforma web de agendamiento de citas para atención al público, permitiendo la gestión remota de horarios y la sincronización en tiempo real de la información.',
    technologies: ['React 18', 'TailwindCSS', 'Node.js', 'Express', 'MongoDB', 'Mongoose']
  }
];
---

<section id="experiencia" class="section experience">
  <div class="container">
    <h2 class="section-title">Experiencia</h2>
    
    <div class="timeline">
      {experiences.map((exp, index) => (
        <article class="timeline-item" style={`animation-delay: ${index * 0.2}s`}>
          <div class="timeline-marker">
            <div class="marker-dot"></div>
            <div class="marker-line"></div>
          </div>
          
          <div class="timeline-content glass-card">
            <div class="exp-header">
              <div class="exp-title-group">
                <h3 class="exp-company">{exp.company}</h3>
                <span class="exp-role">{exp.role}</span>
              </div>
              <div class="exp-meta">
                <span class="exp-period">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M12 6v6l4 2"/>
                  </svg>
                  {exp.period}
                </span>
                <span class="exp-location">{exp.location}</span>
              </div>
            </div>
            
            <p class="exp-description">{exp.description}</p>
            
            {exp.highlight && (
              <div class="exp-highlight">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
                <span>{exp.highlight}</span>
              </div>
            )}
            
            {exp.note && (
              <p class="exp-note">{exp.note}</p>
            )}
            
            <div class="exp-technologies">
              {exp.technologies.map(tech => (
                <span class="tag">{tech}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .experience {
    position: relative;
  }
  
  .timeline {
    position: relative;
    padding-left: 40px;
  }
  
  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--accent-primary), var(--accent-tertiary));
    opacity: 0.3;
  }
  
  .timeline-item {
    position: relative;
    margin-bottom: var(--space-lg);
  }
  
  .timeline-item:last-child {
    margin-bottom: 0;
  }
  
  .timeline-marker {
    position: absolute;
    left: -40px;
    top: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .marker-dot {
    width: 16px;
    height: 16px;
    background: var(--bg-primary);
    border: 3px solid var(--accent-primary);
    border-radius: 50%;
    position: relative;
    z-index: 1;
  }
  
  .marker-line {
    width: 2px;
    flex: 1;
    background: linear-gradient(to bottom, var(--accent-primary), transparent);
    margin-top: 8px;
  }
  
  .timeline-item:last-child .marker-line {
    display: none;
  }
  
  .timeline-content {
    padding: var(--space-md);
    transition: all 0.3s ease;
  }
  
  .timeline-content:hover {
    border-color: var(--accent-primary);
    transform: translateX(8px);
  }
  
  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-sm);
    flex-wrap: wrap;
    gap: var(--space-sm);
  }
  
  .exp-title-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  
  .exp-company {
    font-size: 1.25rem;
    font-weight: 700;
  }
  
  .exp-role {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--accent-primary);
  }
  
  .exp-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
  }
  
  .exp-period {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-secondary);
  }
  
  .exp-period svg {
    color: var(--accent-secondary);
  }
  
  .exp-location {
    font-size: 0.8rem;
    color: var(--text-secondary);
    opacity: 0.7;
  }
  
  .exp-description {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-sm);
  }
  
  .exp-technologies {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .exp-highlight {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(168, 85, 247, 0.1);
    border: 1px solid rgba(168, 85, 247, 0.2);
    border-radius: 100px;
    font-size: 0.8rem;
    color: var(--accent-primary);
    margin-bottom: var(--space-sm);
    align-self: flex-start;
  }
  
  .exp-projects {
    margin-bottom: var(--space-sm);
    padding: var(--space-sm);
    background: var(--bg-tertiary);
    border-radius: 8px;
  }
  
  .projects-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  
  .project-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
  }
  
  .project-item::before {
    content: '>';
    font-family: var(--font-mono);
    color: var(--accent-primary);
    font-size: 0.8rem;
  }
  
  .project-name {
    color: var(--text-primary);
  }
  
  .project-type {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-secondary);
    padding: 0.125rem 0.5rem;
    background: var(--bg-secondary);
    border-radius: 4px;
  }
  
  .exp-note {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-secondary);
    font-style: italic;
    margin-bottom: var(--space-sm);
  }
  
  @media (max-width: 640px) {
    .exp-header {
      flex-direction: column;
    }
    
    .exp-meta {
      align-items: flex-start;
    }
  }
</style>
