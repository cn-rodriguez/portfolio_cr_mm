---
const projects = [
  {
    title: 'Plataforma de Agendamiento',
    description: 'Sistema web completo de agendamiento de citas para atención al público, con gestión remota de horarios y sincronización en tiempo real. Elimina errores en el proceso de reservas.',
    technologies: ['React 18', 'TailwindCSS', 'Node.js', 'Express', 'MongoDB'],
    year: '2022-2023',
    type: 'Full Stack',
    highlight: 'Práctica Profesional'
  }
];

const education = {
  title: 'Analista Programador',
  institution: 'Centro de Formación Técnica INACAP',
  location: 'La Serena, Chile',
  period: 'Marzo 2020 – Julio 2023'
};
---

<section id="proyectos" class="section projects">
  <div class="container">
    <h2 class="section-title">Proyectos</h2>
    
    <div class="projects-grid">
      {projects.map((project, index) => (
        <article class="project-card glass-card" style={`animation-delay: ${index * 0.2}s`}>
          <div class="project-header">
            <span class="project-type">{project.type}</span>
            <span class="project-year">{project.year}</span>
          </div>
          
          <h3 class="project-title">{project.title}</h3>
          
          <p class="project-description">{project.description}</p>
          
          <div class="project-highlight">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
            <span>{project.highlight}</span>
          </div>
          
          <div class="project-technologies">
            {project.technologies.map(tech => (
              <span class="tag">{tech}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
    
    <div class="education-section glass-card">
      <div class="education-header">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
          <path d="M6 12v5c3 3 9 3 12 0v-5"/>
        </svg>
        <div>
          <h3 class="education-title">{education.title}</h3>
          <span class="education-institution">{education.institution}</span>
        </div>
      </div>
      <div class="education-meta">
        <span>{education.location}</span>
        <span class="separator">·</span>
        <span class="education-period">{education.period}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .projects {
    position: relative;
  }
  
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }
  
  .project-card {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    position: relative;
    overflow: hidden;
  }
  
  .project-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent-primary), var(--accent-tertiary));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }
  
  .project-card:hover::before {
    transform: scaleX(1);
  }
  
  .project-card:hover {
    transform: translateY(-8px);
    border-color: var(--accent-primary);
  }
  
  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-sm);
  }
  
  .project-type {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  
  .project-year {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-secondary);
  }
  
  .project-title {
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }
  
  .project-description {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-sm);
    flex-grow: 1;
  }
  
  .project-highlight {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(168, 85, 247, 0.1);
    border: 1px solid rgba(168, 85, 247, 0.2);
    border-radius: 100px;
    font-size: 0.8rem;
    color: var(--accent-primary);
    margin-bottom: var(--space-sm);
    align-self: flex-start;
  }
  
  .project-technologies {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
  }
  
  .education-section {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  
  .education-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }
  
  .education-header svg {
    color: var(--accent-primary);
  }
  
  .education-title {
    font-size: 1.1rem;
    font-weight: 600;
  }
  
  .education-institution {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }
  
  .education-meta {
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-family: var(--font-mono);
  }
  
  .education-meta .separator {
    color: var(--accent-primary);
    margin: 0 0.5rem;
  }
</style>
